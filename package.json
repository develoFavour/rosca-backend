{
  "name": "ajosave-api",
  "version": "1.0.0",
  "description": "Production-grade ROSCA savings group backend API with JWT auth, cycle engine, payouts, Socket.io, Swagger, and Postman documentation.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run typecheck",
    "lint": "npm run typecheck",
    "docs:openapi": "tsx src/docs/write-openapi.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rosca",
    "ajo",
    "esusu",
    "fintech",
    "express",
    "mongodb",
    "socket.io"
  ],
  "author": "Favour Opia",
  "license": "MIT",
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.27.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
