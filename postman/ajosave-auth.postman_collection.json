    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "otpCode",
      "value": ""
    },
    {
      "key": "groupId",
      "value": ""
    },
    {
      "key": "inviteCode",
      "value": ""
    },
    {
      "key": "cycleId",
      "value": ""
    },
    {
      "key": "paymentReference",
      "value": ""
    },
    {
      "key": "contributionId",
      "value": ""
    },
    {
      "key": "bankCode",
      "value": "058"
    },
    {
      "key": "bankName",
      "value": "Guaranty Trust Bank"
    },
