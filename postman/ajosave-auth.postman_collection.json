  "item": [
    {
      "name": "Auth",
      "description": "Registration, OTP verification, login, refresh-token rotation, logout, and password reset endpoints.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ada Okafor\",\n  \"email\": \"ada@example.com\",\n  \"phone\": \"+2348012345678\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\",\n  \"otpCode\": \"{{otpCode}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\",\n  \"otpCode\": \"{{otpCode}}\",\n  \"newPassword\": \"NewPassword123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Paystack-backed contribution payment endpoints will be added in the payments/contributions phase.",
      "item": []
    },
    {
      "name": "Groups",
      "description": "Create, join, manage, start, and audit ROSCA savings groups.",
      "item": [
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/groups",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lekki Ajo Circle\",\n  \"description\": \"Monthly savings group for trusted friends\",\n  \"contributionAmount\": 10000,\n  \"frequency\": \"monthly\",\n  \"maxMembers\": 3,\n  \"rotationOrder\": \"sequential\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.group) {",
                  "  pm.collectionVariables.set('groupId', json.data.group.id);",
                  "  pm.collectionVariables.set('inviteCode', json.data.group.inviteCode);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Groups",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups"
          }
        },
        {
          "name": "Get Group Details",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}"
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/groups/{{groupId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated monthly savings group description\"\n}"
            }
          }
        },
        {
          "name": "Join Group",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/groups/join",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"{{inviteCode}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.group) {",
                  "  pm.collectionVariables.set('groupId', json.data.group.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Leave Group",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}/leave"
          }
        },
        {
          "name": "Start Group",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}/start"
          }
        },
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}/members"
          }
        },
        {
          "name": "Group Activity",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}/activity?page=1&limit=20"
          }
        },
        {
          "name": "Delete Pending Group",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/groups/{{groupId}}"
          }
        }
      ]
    },
    {
      "name": "Contributions",
      "description": "Paystack-backed contribution payments, current cycle status, and contribution history.",
      "item": [
        {
          "name": "Initialize Contribution Payment",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/contributions/initialize-payment",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.payment) {",
                  "  pm.collectionVariables.set('paymentReference', json.data.payment.reference);",
                  "}",
                  "if (json.data && json.data.cycle) {",
                  "  pm.collectionVariables.set('cycleId', json.data.cycle.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Contribution Payment",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/contributions/verify-payment",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{paymentReference}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.contribution) {",
                  "  pm.collectionVariables.set('contributionId', json.data.contribution.id);",
                  "}",
                  "if (json.data && json.data.cycle) {",
                  "  pm.collectionVariables.set('cycleId', json.data.cycle.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Contribution Status",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/contributions/status/{{groupId}}"
          }
        },
        {
          "name": "List Group Contributions",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/contributions/group/{{groupId}}?page=1&limit=20"
          }
        },
        {
          "name": "List Cycle Contributions",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/contributions/cycle/{{cycleId}}"
          }
        },
        {
          "name": "List My Contributions",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/contributions/my/{{groupId}}"
          }
        },
        {
          "name": "Confirm Contribution",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/contributions/{{contributionId}}/confirm"
          }
        }
      ]
    },
    {
      "name": "Payouts",
      "description": "Withdrawal account setup and manual payout approval through Paystack transfers.",
      "item": [
        {
          "name": "List Banks",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/withdrawal-accounts/banks"
          }
        },
        {
          "name": "Resolve Withdrawal Account",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/withdrawal-accounts/resolve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"{{accountNumber}}\",\n  \"bankCode\": \"{{bankCode}}\"\n}"
            }
          }
        },
        {
          "name": "Save Withdrawal Account",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/withdrawal-accounts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"{{accountNumber}}\",\n  \"bankCode\": \"{{bankCode}}\",\n  \"bankName\": \"{{bankName}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Withdrawal Account",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/withdrawal-accounts/me"
          }
        },
        {
          "name": "Request Payout",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/payouts/request",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.payout) {",
                  "  pm.collectionVariables.set('payoutId', json.data.payout.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Approve Payout",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payouts/{{payoutId}}/approve"
          }
        },
        {
          "name": "Reject Payout",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/payouts/{{payoutId}}/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Recipient needs to update withdrawal account first.\"\n}"
            }
          }
        },
        {
          "name": "Get Payout",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payouts/{{payoutId}}"
          }
        },
        {
          "name": "List Group Payouts",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payouts/group/{{groupId}}?page=1&limit=20"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "description": "Notification endpoints and realtime event docs will be added in Phase 5.",
      "item": []
    }
  ]
}
